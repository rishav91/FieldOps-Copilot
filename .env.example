# Copy to .env and fill in. Never commit .env (see .gitignore).

# --- Datastore (ADR-010) ---
DATABASE_URL=postgresql+psycopg://fieldops:fieldops@localhost:5432/fieldops

# --- LLM providers (ADR-003): OpenAI primary, Grok cheap tier ---
# Both are optional for the Phase-0 skeleton: classify/draft are stubs and run
# offline. Keys are only exercised by `fieldops llm-health`.
OPENAI_API_KEY=
XAI_API_KEY=

# Model bindings (provider-agnostic LLMClient)
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
GROK_CHEAP_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# Embedding dimension must match OPENAI_EMBED_MODEL (text-embedding-3-small = 1536).
EMBEDDING_DIM=1536

# --- Pipeline knobs (config-driven; no redeploy to retune — ARCHITECTURE §8) ---
GATE_THRESHOLD=0.75
AGENT_TURN_CAP=6
AGENT_SPLIT_CAP=3
DAILY_SPEND_CEILING_USD=5.00

# --- Demo scope (PRD §5) ---
TARGET_BOROUGH=BROOKLYN
LOG_LEVEL=INFO
